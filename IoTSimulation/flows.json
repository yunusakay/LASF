    {
        "id": "autonomous_logic",
        "type": "function",
        "z": "bbbeb38bf0287061",
        "name": "Otonom Karar Zekası",
        "func": "let env = msg.payload;\nlet commands = [];\n\n// Kural 1: Kabin Nemi %60'ı geçerse Nem Toplayıcıyı (Dehumidifier) aç\nif (env.chamber_humidity > 60.0) {\n    commands.push({ payload: { \"device\": \"dehumidifier\", \"action\": true } });\n} else if (env.chamber_humidity < 50.0) {\n    commands.push({ payload: { \"device\": \"dehumidifier\", \"action\": false } });\n}\n\n// Kural 2: Sıcaklık artarsa Fanı aç\nif (env.chamber_temperature > 24.5) {\n    commands.push({ payload: { \"device\": \"ventilation_fan\", \"action\": true } });\n} else if (env.chamber_temperature < 23.5) {\n    commands.push({ payload: { \"device\": \"ventilation_fan\", \"action\": false } });\n}\n\n// KURAL 3: OTONOM NPK GÜBRELEME SİSTEMİ\n// Sensörler minerallerden herhangi birinin kritik seviyenin altına düştüğünü ölçerse gübre pompasını AÇ!\nif (env.mineral_n < 50 || env.mineral_p < 25 || env.mineral_k < 60) {\n    commands.push({ payload: { \"device\": \"npk_doser\", \"action\": true } });\n} \n// Mineraller doygunluk noktasına ulaşırsa (fazla gübre zehirler ve israftır) pompayı KAPAT!\nelse if (env.mineral_n > 110 && env.mineral_p > 50 && env.mineral_k > 120) {\n    commands.push({ payload: { \"device\": \"npk_doser\", \"action\": false } });\n}\n\nreturn [commands];",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
