        "z": "bbbeb38bf0287061",
        "name": "Aerogel Otonom Zekası",
        "func": "let env = msg.payload;\nlet commands = [];\n\n// Kural 1: Eğer Nem NASA sınırını (%66) zorluyorsa Aerogel'i aç\nif (env.chamber_humidity > 60.0) {\n    commands.push({ payload: { \"device\": \"aerogel_collector\", \"action\": true } });\n} else if (env.chamber_humidity < 50.0) {\n    // Nem güvenli seviyedeyse Aerogel'i kapat\n    commands.push({ payload: { \"device\": \"aerogel_collector\", \"action\": false } });\n}\n\n// Kural 2: Sıcaklık artarsa Fanı aç\nif (env.chamber_temperature > 23.8) {\n    commands.push({ payload: { \"device\": \"ventilation_fan\", \"action\": true } });\n} else if (env.chamber_temperature < 23.2) {\n    commands.push({ payload: { \"device\": \"ventilation_fan\", \"action\": false } });\n}\n\n// Tüm komutları sırayla gönder\nreturn [commands];",
        "outputs": 1,
        "noerr": 0,
