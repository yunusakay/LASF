    {
        "id": "addon_logic",
        "type": "function",
        "z": "bbbeb38bf0287061",
        "name": "pH & EC Simüle Et + Karar",
        "func": "// Eski sıcaklık verisini alıyoruz (Yoksa 23 varsayıyoruz)\nlet temp = msg.payload.Temp_degC_ISS || 23.0;\n\n// 3 bitki için ortak yaşam (Sweet Spot) pH ve EC simülasyonu\nlet current_pH = (5.8 + (Math.random() * 0.4 - 0.2)).toFixed(2);\nlet current_EC = (1.5 + (Math.random() * 0.3 - 0.15)).toFixed(2);\n\nlet status = \"✅ OPTİMAL: 3'lü Ekosistem Stabil\";\nlet color = \"#00ff00\";\n\nif (current_EC < 1.4) {\n    status = \"⚠️ MİNERAL DÜŞÜK: EC Pompası Devrede\";\n    color = \"#ffaa00\";\n} else if (current_pH > 6.0) {\n    status = \"⚠️ pH YÜKSEK: Asit Dozajı Yapılıyor\";\n    color = \"#ff0000\";\n} else if (temp > 23.4) {\n    status = \"⚠️ SICAKLIK KRİTİK: Fanlar Açık\";\n    color = \"#ff0000\";\n}\n\n// Tüm verileri tek bir pakette birleştir (Web sitesi için)\nmsg.payload.pH_Level = Number(current_pH);\nmsg.payload.EC_Level = Number(current_EC);\nmsg.payload.SystemStatus = status;\nmsg.color = color;\n\n// 1. Çıkış: WebSocket (Tüm veriler)\n// 2. Çıkış: pH Göstergesi\n// 3. Çıkış: EC Göstergesi\n// 4. Çıkış: Durum Metni\nreturn [\n    msg, \n    {payload: msg.payload.pH_Level}, \n    {payload: msg.payload.EC_Level}, \n    {payload: status, color: color}\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
